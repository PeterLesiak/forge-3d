{
    "name": "@forge-3d/core",
    "type": "module",
    "scripts": {
        "build": "pnpm run build:js && pnpm run build:dts",
        "build:js": "node esbuild.config.js",
        "build:dts": "tsc -p tsconfig.build.json && resolve-tspaths -p tsconfig.build.json",
        "lint": "tsc -p tsconfig.json"
    },
    "exports": {
        ".": "./build/index.js",
        "./*": "./build/*.js",
        "./*.js": "./build/*.js"
    },
    "devDependencies": {
        "@forge-3d/internal": "workspace:^"
    }
}
