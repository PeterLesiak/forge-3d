{
    "name": "@forge-3d/core",
    "type": "module",
    "scripts": {
        "build": "node ./build.js",
        "lint": "tsc -p tsconfig.json"
    },
    "exports": {
        ".": {
            "import": "./build/index.js",
            "require": "./build/index.cjs"
        },
        "./*": {
            "import": "./build/*.js",
            "require": "./build/*.cjs"
        },
        "./*.js": {
            "import": "./build/*.js",
            "require": "./build/*.cjs"
        }
    },
    "devDependencies": {
        "@forge-3d/internal": "workspace:^"
    }
}
