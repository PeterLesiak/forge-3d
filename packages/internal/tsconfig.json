{
    "compilerOptions": {
        "lib": ["ES2020"],
        "module": "ESNext",
        "target": "ESNext",
        "moduleDetection": "force",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "skipLibCheck": true,
        "checkJs": true,
        "resolveJsonModule": true,

        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true,
        "verbatimModuleSyntax": true
    }
}
