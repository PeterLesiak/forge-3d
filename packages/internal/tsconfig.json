{
    "$schema": "https://json.schemastore.org/tsconfig",

    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",

        "strict": true,
        "isolatedModules": true,
        "noEmit": true,
        "skipLibCheck": true,
        "checkJs": true,
        "noUnusedParameters": false,
        "allowImportingTsExtensions": true
    }
}
