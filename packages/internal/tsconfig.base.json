{
    "$schema": "https://json.schemastore.org/tsconfig",

    "compilerOptions": {
        "target": "ES2015",
        "lib": ["DOM", "ES2020"],
        "module": "ESNext",
        "moduleResolution": "Bundler",

        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "checkJs": true,
        "noUnusedParameters": false
    }
}
